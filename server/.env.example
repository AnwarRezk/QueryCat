# Configuration Profile — copy this to .env in the server/ directory

# ── LLM Configuration ──────────────────────────────────────
# Set to 'True' to use OpenAI GPT-4o, 'False' to use Ollama
USE_OPENAI=True

# Required if USE_OPENAI=True
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required if USE_OPENAI=False
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Server Configuration ───────────────────────────────────
HOST=0.0.0.0
PORT=3001

# ── Storage Configuration ──────────────────────────────────
# Paths relative to the server/ directory
CHROMA_PERSIST_DIR=./chroma_data
UPLOAD_DIR=./uploads
SESSIONS_DIR=./sessions
